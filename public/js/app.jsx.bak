                ? true
                : localStorage.getItem('diffHighlightingEnabled') === 'true',
            moveDetectionEnabled: localStorage.getItem('moveDetectionEnabled') === null
                ? true
                : localStorage.getItem('moveDetectionEnabled') === 'true'
        };

        // Combined FileList component to display all comparison types
        const FileList = ({ files, timeFiles, onSelectFile, onSelectTimeFile, selectedFile, selectedTimeFile, searchQuery, fileContents }) => {
            if (files.length === 0 && timeFiles.length === 0) {
                return (
                    <div className="alert alert-info">
                        No file comparisons available.
                    </div>
                );
            }

            // Combine both comparison types into a single array
            const combinedFiles = [
                ...files.map(file => ({
                    ...file,
                    type: 'oldNew',
                    timestamp: Math.max(
                        (file.oldFile && file.oldFile.mtime) || 0, 
                        (file.newFile && file.newFile.mtime) || 0
                    )
                })),
                ...timeFiles.map(file => ({
                    ...file,
                    type: 'time',
                    timestamp: file.timestamp
                }))
            ];

            // Sort combined files by timestamp (newest first)
            combinedFiles.sort((a, b) => b.timestamp - a.timestamp);

            const lowerQuery = (searchQuery || '').trim().toLowerCase();
            const displayedFiles = lowerQuery
                ? combinedFiles.filter(file => {
                    const isOldNew = file.type === 'oldNew';
                    const origIdx = isOldNew
                        ? files.findIndex(f => 
                            f.oldFile.path === file.oldFile.path && 
                            f.newFile.path === file.newFile.path
                        )
                        : timeFiles.findIndex(f => 
                            f.newerFile.path === file.newerFile.path && 
                            f.olderFile.path === file.olderFile.path
                        );
                    
                    const entry = fileContents[`${file.type}-${origIdx}`] || {};
                    const hayArray = [file.commandRan || ''];
                    if (isOldNew) {
                        hayArray.push(
                            (file.oldFile && file.oldFile.filename) || '',
                            (file.newFile && file.newFile.filename) || ''
                        );
                    } else {
                        hayArray.push(
                            (file.olderFile && file.olderFile.filename) || '',
                            (file.newerFile && file.newerFile.filename) || ''
                        );
                    }
                    hayArray.push(entry.old || '', entry.new || '');
                    const hay = hayArray.join(' ').toLowerCase();
                    return hay.includes(lowerQuery);
                  })
                : combinedFiles;

            return (
                <div className="file-list">
                    <div className="list-group">
                        {displayedFiles.map((file, index) => {
                            const isOldNew = file.type === 'oldNew';
                            const isSelected = isOldNew 
                                ? selectedFile === files.findIndex(f => 
                                    f.oldFile.path === file.oldFile.path && 
                                    f.newFile.path === file.newFile.path
                                )
                                : selectedTimeFile === timeFiles.findIndex(f => 
                                    f.newerFile.path === file.newerFile.path && 
                                    f.olderFile.path === file.olderFile.path
                                );
                            
                            return (
                                <div 
                                    key={`${file.type}-${index}`} 
                                    className={`file-entry ${isSelected ? 'selected' : ''}`}
                                    onClick={() => {
                                        if (isOldNew) {
                                            onSelectFile(files.findIndex(f => 
                                                f.oldFile.path === file.oldFile.path && 
                                                f.newFile.path === file.newFile.path
                                            ));
                                        } else {
                                            onSelectTimeFile(timeFiles.findIndex(f => 
                                                f.newerFile.path === file.newerFile.path && 
                                                f.olderFile.path === file.olderFile.path
                                            ));
                                        }
                                    }}
                                >
                                    <div className={`type-indicator ${isOldNew ? 'type-old-new' : 'type-time'}`}></div>
                                    <div className="file-entry-content">
                                        {isOldNew ? file.commandRan : file.commandRan}
                                        {!isOldNew && (
                                            <div>
                                                <span className="comparison-type type-time-label">Time Comparison</span>
                                                <span className="time-diff">{file.timeDiff}</span>
                                            </div>
                                        )}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>
            );
        };

        // Main App component
        const App = () => {
            const [files, setFiles] = React.useState([]);
            const [timeFiles, setTimeFiles] = React.useState([]);
            const [selectedFileIndex, setSelectedFileIndex] = React.useState(null);
            const [selectedTimeFileIndex, setSelectedTimeFileIndex] = React.useState(null);
            const [currentComparisonType, setCurrentComparisonType] = React.useState(null); // 'oldNew' or 'time'
            const [oldContent, setOldContent] = React.useState("");
            const [newContent, setNewContent] = React.useState("");
            const [newerContent, setNewerContent] = React.useState("");
            const [olderContent, setOlderContent] = React.useState("");
            const [loading, setLoading] = React.useState(true);
            const [error, setError] = React.useState(null);
            const [keywords, setKeywords] = React.useState({});
            const [highlightingEnabled, setHighlightingEnabled] = React.useState(window.appState.highlightingEnabled);
            const [diffHighlightingEnabled, setDiffHighlightingEnabled] = React.useState(window.appState.diffHighlightingEnabled);
            const [moveDetectionEnabled, setMoveDetectionEnabled] = React.useState(window.appState.moveDetectionEnabled);
            const [sidebarCollapsed, setSidebarCollapsed] = React.useState(false);
            const [diffMode, setDiffMode] = React.useState('char');
            const [searchQuery, setSearchQuery] = React.useState('');
            const [fileContents, setFileContents] = React.useState({});

            // Direct connection between toggle and React state
            const setHighlightState = (enabled) => {
                // Update React state
                setHighlightingEnabled(enabled);
                
                // Update global app state
                window.appState.highlightingEnabled = enabled;
                
                // Update localStorage
                localStorage.setItem('highlightingEnabled', enabled);
                
                // Update the DOM toggle
                const globalToggle = document.getElementById('global-highlight-toggle');
                if (globalToggle && globalToggle.checked !== enabled) {
                    globalToggle.checked = enabled;
                }
                
                // Update the toggle label
                const label = document.querySelector('.highlight-toggle-header .toggle-label');
                if (label) {
                    label.textContent = `Highlights ${enabled ? 'ON' : 'OFF'}`;
                }
            };

            const setDiffHighlightState = (enabled) => {
                // Update React state
                setDiffHighlightingEnabled(enabled);
                
                // Update global app state
                window.appState.diffHighlightingEnabled = enabled;
                
                // Update localStorage
                localStorage.setItem('diffHighlightingEnabled', enabled);
                
                // Update the DOM toggle
                const diffToggle = document.getElementById('diff-highlight-toggle');
                if (diffToggle && diffToggle.checked !== enabled) {
                    diffToggle.checked = enabled;
                }
            };

            const setMoveDetectionState = (enabled) => {
                // Update React state
                setMoveDetectionEnabled(enabled);
                
                // Update global app state
                window.appState.moveDetectionEnabled = enabled;
                
                // Update localStorage
                localStorage.setItem('moveDetectionEnabled', enabled);
                
                // Update the DOM toggle
                const moveToggle = document.getElementById('move-detection-toggle');
                if (moveToggle && moveToggle.checked !== enabled) {
                    moveToggle.checked = enabled;
                }
            };

            // Listen for highlight toggle events from the global toggle
            React.useEffect(() => {
                const handleHighlightToggle = (event) => {
                    setHighlightState(event.detail.enabled);
                };
                
                const handleDiffHighlightToggle = (event) => {
                    setDiffHighlightState(event.detail.enabled);
                };
                
                const handleMoveDetectionToggle = (event) => {
                    setMoveDetectionState(event.detail.enabled);
                };
                
                const handleDiffModeToggle = (event) => setDiffMode(event.detail.mode);
                
                const handleNewOnlyToggle = (event) => {
                    const enabled = event.detail.enabled;
                    // Update localStorage
                    localStorage.setItem('newOnlyEnabled', enabled);
                    // Update global state
                    window.appState.newOnlyEnabled = enabled;
                };
                
                document.addEventListener('highlightToggleChanged', handleHighlightToggle);
                document.addEventListener('diffHighlightToggleChanged', handleDiffHighlightToggle);
                document.addEventListener('moveDetectionToggleChanged', handleMoveDetectionToggle);
                document.addEventListener('diffModeToggle', handleDiffModeToggle);
                document.addEventListener('newOnlyToggleChanged', handleNewOnlyToggle);
                
                // Initialize the toggle state
                setHighlightState(window.appState.highlightingEnabled);
                setDiffHighlightState(window.appState.diffHighlightingEnabled);
                setMoveDetectionEnabled(window.appState.moveDetectionEnabled);
                
                // Initialize diff mode from header toggle
                const initialModeToggle = document.getElementById('diff-mode-toggle');
                if (initialModeToggle) setDiffMode(initialModeToggle.checked ? 'word' : 'char');
                
                return () => {
                    document.removeEventListener('highlightToggleChanged', handleHighlightToggle);
                    document.removeEventListener('diffHighlightToggleChanged', handleDiffHighlightToggle);
                    document.removeEventListener('moveDetectionToggleChanged', handleMoveDetectionToggle);
                    document.removeEventListener('diffModeToggle', handleDiffModeToggle);
                    document.removeEventListener('newOnlyToggleChanged', handleNewOnlyToggle);
                };
            }, []);

            // Fetch all matching file pairs on component mount
            React.useEffect(() => {
                fetchFiles();
                fetchTimeComparisons();
                fetchKeywords();
                
                // Set up polling to check for new files (every 10 seconds)
                const interval = setInterval(() => {
                    fetchFiles();
                    fetchTimeComparisons();
                    fetchKeywords();
                }, 10000);
                
                // Clear interval on component unmount
                return () => clearInterval(interval);
            }, []);

            // Highlight search terms in diff view after each update
            React.useEffect(() => {
                if (!window.Mark) return;
                document.querySelectorAll('.diff-container').forEach(container => {
                    const marker = new Mark(container);
                    marker.unmark({ done: () => {
                        if (searchQuery) marker.mark(searchQuery);
                    }});
                });
            }, [searchQuery, oldContent, newContent, newerContent, olderContent, diffMode, currentComparisonType]);

            // Fetch files from the API
            const fetchFiles = () => {
                fetch('/api/files')
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Failed to fetch files');
                        }
                        return response.json();
                    })
                    .then(data => {
                        setFiles(data);
                        data.forEach((file, idx) => {
                            fetch(
                                `/api/compare?oldPath=${encodeURIComponent(file.oldFile.path)}&newPath=${encodeURIComponent(file.newFile.path)}`
                            )
                                .then(res => { if (!res.ok) throw new Error('Failed to fetch file content'); return res.json(); })
                                .then(d => setFileContents(prev => ({
                                    ...prev,
                                    [`oldNew-${idx}`]: { old: d.oldContent, new: d.newContent }
                                })))
                                .catch(console.error);
                        });
                        setLoading(false);
                    })
                    .catch(err => {
                        setError(err.message);
                        setLoading(false);
                    });
            };

            // Fetch time-based comparisons from the API
            const fetchTimeComparisons = () => {
                fetch('/api/time-comparisons')
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Failed to fetch time comparisons');
                        }
                        return response.json();
                    })
                    .then(data => {
                        setTimeFiles(data);
                        data.forEach((file, idx) => {
                            fetch(
                                `/api/compare?oldPath=${encodeURIComponent(file.olderFile.path)}&newPath=${encodeURIComponent(file.newerFile.path)}`
                            )
                                .then(res => { if (!res.ok) throw new Error('Failed to fetch time file content'); return res.json(); })
                                .then(d => setFileContents(prev => ({
                                    ...prev,
                                    [`time-${idx}`]: { old: d.oldContent, new: d.newContent }
                                })))
                                .catch(console.error);
                        });
                        setLoading(false);
                    })
                    .catch(err => {
                        setError(err.message);
                        setLoading(false);
                    });
            };

            // Fetch keywords from the API
            const fetchKeywords = () => {
                fetch('/api/keywords')
                    .then(response => {
                        if (!response.ok) {
                            throw new Error("Failed to fetch keywords");
                        }
                        return response.json();
                    })
                    .then(data => {
                        setKeywords(data);
                        console.log("Loaded keywords:", Object.keys(data).length);
                    })
                    .catch(err => {
                        console.error("Error fetching keywords:", err.message);
                    });
            };

            // Handle file selection for Old vs New comparison
            const handleFileSelect = (index) => {
                // Clear any selected time comparison
                setSelectedTimeFileIndex(null);
                setSelectedFileIndex(index);
                setCurrentComparisonType('oldNew');
                
                const selectedFile = files[index];
                
                // Fetch file contents for comparison
                fetch(`/api/compare?oldPath=${encodeURIComponent(selectedFile.oldFile.path)}&newPath=${encodeURIComponent(selectedFile.newFile.path)}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Failed to fetch file contents');
                        }
                        return response.json();
                    })
                    .then(data => {
                        setOldContent(data.oldContent);
                        setNewContent(data.newContent);
                    })
                    .catch(err => {
                        setError(err.message);
                    });
            };

            // Handle file selection for Time Comparison
            const handleTimeFileSelect = (index) => {
                // Clear any selected old/new comparison
                setSelectedFileIndex(null);
                setSelectedTimeFileIndex(index);
                setCurrentComparisonType('time');
                
                const selectedFile = timeFiles[index];
                
                // Fetch file contents for comparison
                fetch(`/api/compare?oldPath=${encodeURIComponent(selectedFile.olderFile.path)}&newPath=${encodeURIComponent(selectedFile.newerFile.path)}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Failed to fetch file contents');
                        }
                        return response.json();
                    })
                    .then(data => {
                        setOlderContent(data.oldContent);
                        setNewerContent(data.newContent);
                    })
                    .catch(err => {
                        setError(err.message);
                    });
            };

            if (loading) {
                return (
                    <div className="app-container">
                        <div className="file-list-section">
                            <div className="loading">
                                <div className="spinner-border text-primary" role="status">
                                    <span className="visually-hidden">Loading...</span>
                                </div>
                                <p>Loading files...</p>
                            </div>
                        </div>
                        <div className="comparison-section">
                            <div className="loading">
                                <p>Waiting for file selection...</p>
                            </div>
                        </div>
                    </div>
                );
            }

            if (error) {
                return (
                    <div className="alert alert-danger">
                        Error: {error}
                    </div>
                );
            }

            // Function to highlight keywords in text
            const highlightKeywords = (text, keywords, highlightingEnabled) => {
                if (!highlightingEnabled || !keywords || Object.keys(keywords).length === 0) {
                    return <span>{text}</span>;
                }
                
                // Create a regex pattern from all keywords
                const keywordPatterns = Object.keys(keywords).map(k => 
                    k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') // Escape regex special chars
                ).join('|');
                
                if (!keywordPatterns) {
                    return <span>{text}</span>;
                }
                
                const regex = new RegExp(`(${keywordPatterns})`, 'gi');
                const parts = text.split(regex);
                
                return (
                    <React.Fragment>
                        {parts.map((part, i) => {
                            const lowercasePart = part.toLowerCase();
                            const keywordMatch = Object.keys(keywords).find(k => k.toLowerCase() === lowercasePart);
                            
                            if (keywordMatch) {
                                const color = keywords[keywordMatch];
                                return (
                                    <span 
                                        key={i} 
                                        className="highlight-keyword" 
                                        style={{ 
                                            textDecoration: 'underline',
                                            textDecorationColor: color,
                                            textDecorationThickness: '2px'
                                        }}>
                                        {part}
                                    </span>
                                );
                            }
                            
                            return <span key={i}>{part}</span>;
                        })}
                    </React.Fragment>
                );
            };

            // Word-level diff function using jsdiff
            const createWordDiff = (oldText, newText, diffHighlightingEnabled, moveDetectionEnabled, keywords, highlightingEnabled) => {
                const oldLines = oldText.split('\n');
                const newLines = newText.split('\n');
                
                if (!diffHighlightingEnabled && !moveDetectionEnabled) {
                    // No highlighting: render plain text rows
                    return (
                        <table className="diff-table">
                            <tbody>
                                {Math.max(oldLines.length, newLines.length) > 0 &&
                                    [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => (
                                        <tr key={i}>
                                            <td className="line-number">{i+1}</td>
                                            <td>{oldLines[i] || ''}</td>
                                            <td className="line-number">{i+1}</td>
                                            <td>{newLines[i] || ''}</td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    );
                }
                
                // Create a diff for each line pair
                return (
                    <table className="diff-table">
                        <tbody>
                            {Math.max(oldLines.length, newLines.length) > 0 && 
                                [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => {
                                    const oldLine = oldLines[i] || '';
                                    const newLine = newLines[i] || '';

                                    // Move detection: highlight lines present elsewhere
                                    let oldMovedToLine = -1;
                                    const oldMoved = moveDetectionEnabled && 
                                        oldLine.trim() && // Not empty
                                        oldLine !== newLine && // Current position has different content
                                        newLines.some((line, index) => {
                                            if (index !== i && line === oldLine) { // Different position & exact content match
                                                oldMovedToLine = index + 1; // Store the target line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });
                                    
                                    let newMovedFromLine = -1;
                                    const newMoved = moveDetectionEnabled && 
                                        newLine.trim() && // Not empty
                                        newLine !== oldLine && // Current position has different content
                                        oldLines.some((line, index) => {
                                            if (index !== i && line === newLine) { // Different position & exact content match
                                                newMovedFromLine = index + 1; // Store the source line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });

                                    const oldWordDiff = () => {
                                        if (!oldLine) return null;
                                        if (!diffHighlightingEnabled) return highlightKeywords(oldLine, keywords, highlightingEnabled);
                                        const parts = Diff.diffWordsWithSpace(oldLine, newLine);
                                        return (
                                            <div className="diff-word-line">
                                                {parts.map((part, j) => 
                                                    !part.added ? <span key={j} className={part.removed ? 'word-removed' : ''}>{part.value}</span> : null
                                                )}
                                            </div>
                                        );
                                    };
                                    
                                    const newWordDiff = () => {
                                        if (!newLine) return null;
                                        if (!diffHighlightingEnabled) return highlightKeywords(newLine, keywords, highlightingEnabled);
                                        const parts = Diff.diffWordsWithSpace(oldLine, newLine);
                                        return (
                                            <div className="diff-word-line">
                                                {parts.map((part, j) => 
                                                    !part.removed ? <span key={j} className={part.added ? 'word-added' : ''}>{part.value}</span> : null
                                                )}
                                            </div>
                                        );
                                    };
                                    
                                    return (
                                        <tr key={i}>
                                            <td className={`line-number ${oldMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {oldMoved && oldMovedToLine > 0 && <span className="moved-indicator" data-arrow="→">{oldMovedToLine}</span>}
                                            </td>
                                            <td className={oldMoved ? 'moved' : ''}>{oldWordDiff()}</td>
                                            <td className={`line-number ${newMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {newMoved && newMovedFromLine > 0 && <span className="moved-indicator" data-arrow="←">{newMovedFromLine}</span>}
                                            </td>
                                            <td className={newMoved ? 'moved' : ''}>{newWordDiff()}</td>
                                        </tr>
                                    );
                                })
                            }
                        </tbody>
                    </table>
                );
            };

            // Function to find character-level differences within a line
            const enhancedFindDiffInLines = (oldLine, newLine, keywords) => {
                if (oldLine === newLine) {
                    return {
                        oldFormatted: highlightKeywords(oldLine, keywords, highlightingEnabled),
                        newFormatted: highlightKeywords(newLine, keywords, highlightingEnabled)
                    };
                }
                
                // Simple character-level diff implementation
                let i = 0;
                let j = oldLine.length - 1;
                let k = newLine.length - 1;
                
                // Find common prefix
                while (i <= j && i <= k && oldLine.charAt(i) === newLine.charAt(i)) {
                    i++;
                }
                
                // Find common suffix
                while (j >= i && k >= i && oldLine.charAt(j) === newLine.charAt(k)) {
                    j--;
                    k--;
                }
                
                const oldPrefix = oldLine.substring(0, i);
                const oldDiff = oldLine.substring(i, j + 1);
                const oldSuffix = oldLine.substring(j + 1);
                
                const newPrefix = newLine.substring(0, i);
                const newDiff = newLine.substring(i, k + 1);
                const newSuffix = newLine.substring(k + 1);
                
                // Generate formatted output with inline highlighting and keyword highlighting
                const oldFormatted = (
                    <React.Fragment>
                        {highlightKeywords(oldPrefix, keywords, highlightingEnabled)}
                        <span className="diff-char-removed">{highlightKeywords(oldDiff, keywords, highlightingEnabled)}</span>
                        {highlightKeywords(oldSuffix, keywords, highlightingEnabled)}
                    </React.Fragment>
                );
                
                const newFormatted = (
                    <React.Fragment>
                        {highlightKeywords(newPrefix, keywords, highlightingEnabled)}
                        <span className="diff-char-added">{highlightKeywords(newDiff, keywords, highlightingEnabled)}</span>
                        {highlightKeywords(newSuffix, keywords, highlightingEnabled)}
                    </React.Fragment>
                );
                
                return { oldFormatted, newFormatted };
            };

            // Create line-by-line diff
            const createDiff = (oldText, newText, diffHighlightingEnabled, moveDetectionEnabled) => {
                const oldLines = oldText.split('\n');
                const newLines = newText.split('\n');
                
                if (!diffHighlightingEnabled && !moveDetectionEnabled) {
                    // No highlighting: render plain text rows
                    return (
                        <table className="diff-table">
                            <tbody>
                                {Math.max(oldLines.length, newLines.length) > 0 &&
                                    [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => (
                                        <tr key={i}>
                                            <td className="line-number">{i+1}</td>
                                            <td>{oldLines[i] || ''}</td>
                                            <td className="line-number">{i+1}</td>
                                            <td>{newLines[i] || ''}</td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    );
                }
                
                return (
                    <table className="diff-table">
                        <tbody>
                            {Math.max(oldLines.length, newLines.length) > 0 && 
                                [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => {
                                    const oldLine = oldLines[i] || '';
                                    const newLine = newLines[i] || '';

                                    // Move detection: highlight lines that actually moved positions
                                    let oldMovedToLine = -1;
                                    const oldMoved = moveDetectionEnabled && 
                                        oldLine.trim() && // Not empty
                                        oldLine !== newLine && // Current position has different content
                                        newLines.some((line, index) => {
                                            if (index !== i && line === oldLine) { // Different position & exact content match
                                                oldMovedToLine = index + 1; // Store the target line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });
                                    
                                    let newMovedFromLine = -1;
                                    const newMoved = moveDetectionEnabled && 
                                        newLine.trim() && // Not empty
                                        newLine !== oldLine && // Current position has different content
                                        oldLines.some((line, index) => {
                                            if (index !== i && line === newLine) { // Different position & exact content match
                                                newMovedFromLine = index + 1; // Store the source line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });
                                    
                                    let { oldFormatted, newFormatted } = 
                                        oldLine !== newLine ? enhancedFindDiffInLines(oldLine, newLine, keywords) : 
                                        { 
                                            oldFormatted: highlightKeywords(oldLine, keywords, highlightingEnabled), 
                                            newFormatted: highlightKeywords(newLine, keywords, highlightingEnabled) 
                                        };
                                    
                                    // Choose content based on diffHighlightingEnabled
                                    const oldContent = diffHighlightingEnabled ? oldFormatted : highlightKeywords(oldLine, keywords, highlightingEnabled);
                                    const newContent = diffHighlightingEnabled ? newFormatted : highlightKeywords(newLine, keywords, highlightingEnabled);
                                    
                                    return (
                                        <tr key={i}>
                                            <td className={`line-number ${oldMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {oldMoved && oldMovedToLine > 0 && <span className="moved-indicator" data-arrow="→">{oldMovedToLine}</span>}
                                            </td>
                                            <td className={oldMoved ? 'moved' : ''}>{oldContent}</td>
                                            <td className={`line-number ${newMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {newMoved && newMovedFromLine > 0 && <span className="moved-indicator" data-arrow="←">{newMovedFromLine}</span>}
                                            </td>
                                            <td className={newMoved ? 'moved' : ''}>{newContent}</td>
                                        </tr>
                                    );
                                })
                            }
                        </tbody>
                    </table>
                );
            };

            return (
                <div className="app-container">
                    <div className={`file-list-section ${sidebarCollapsed ? 'collapsed' : ''}`}>
                        <div className="sidebar-header">
                            <h4 className="sidebar-title mb-0">Matching File Pairs</h4>
                            <button 
                                className={`toggle-sidebar ${sidebarCollapsed ? 'collapsed' : ''}`}
                                onClick={() => setSidebarCollapsed(!sidebarCollapsed)}
                                title={sidebarCollapsed ? "Expand sidebar" : "Collapse sidebar"}
                            >
                                <svg viewBox="0 0 8 20" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M7.5 1.5 L0.5 10 L7.5 18.5" strokeWidth="1.5" stroke="white" fill="none"/>
                                </svg>
                                <div class="hotkey-tooltip has-hotkey">Ctrl+E</div>
                            </button>
                        </div>
                        {!sidebarCollapsed && (
                            <div className="search-container mb-2">
                                <input
                                    type="text"
                                    className="form-control"
                                    placeholder="Search files & content"
                                    value={searchQuery}
                                    onChange={e => setSearchQuery(e.target.value)}
                                />
                            </div>
                        )}
                        <FileList 
                            files={files}
                            timeFiles={timeFiles}
                            onSelectFile={handleFileSelect}
                            onSelectTimeFile={handleTimeFileSelect}
                            selectedFile={selectedFileIndex}
                            selectedTimeFile={selectedTimeFileIndex}
                            searchQuery={searchQuery}
                            fileContents={fileContents}
                        />
                    </div>
                    <div className="comparison-section">
                        {currentComparisonType === 'oldNew' ? (
                            <FileComparison 
                                oldContent={oldContent} 
                                newContent={newContent} 
                                fileInfo={selectedFileIndex !== null ? files[selectedFileIndex] : null} 
                                keywords={keywords}
                                highlightingEnabled={highlightingEnabled}
                                diffHighlightingEnabled={diffHighlightingEnabled}
                                moveDetectionEnabled={moveDetectionEnabled}
                                diffMode={diffMode}
                            />
                        ) : currentComparisonType === 'time' ? (
                            <TimeComparisonView 
                                olderContent={olderContent} 
                                newerContent={newerContent} 
                                fileInfo={selectedTimeFileIndex !== null ? timeFiles[selectedTimeFileIndex] : null} 
                                keywords={keywords}
                                highlightingEnabled={highlightingEnabled}
                                diffHighlightingEnabled={diffHighlightingEnabled}
                                moveDetectionEnabled={moveDetectionEnabled}
                                diffMode={diffMode}
                            />
                        ) : (
                            <div className="file-selection-bar">
                                <h2>Welcome to DeltaVision</h2>
                                <p>Compare outputs with powerful diff tools and search capabilities</p>
                                <ul className="welcome-list">
                                    <li>Select a file pair from the sidebar to begin</li>
                                    <li>Search files and content with the search box</li>
                                    <li>Use Move Detection to spot relocated content</li>
                                    <li>Switch between Word and Char diff modes</li>
                                    <li>Toggle highlights: <strong>Ctrl+H</strong></li>
                                    <li>Toggle diffs: <strong>Ctrl+D</strong></li>
                                    <li>Toggle diff mode: <strong>Ctrl+M</strong></li>
                                    <li>Toggle move detection: <strong>Ctrl+R</strong></li>
                                    <li>Toggle sidebar: <strong>Ctrl+E</strong></li>
                                    <li>Navigate pairs: <strong>↑</strong> &amp; <strong>↓</strong></li>
                                </ul>
                            </div>
                        )}
                    </div>
                </div>
            );
        };

        // Function to highlight keywords in text
        const highlightKeywords = (text, keywords, highlightingEnabled) => {
            if (!highlightingEnabled || !keywords || Object.keys(keywords).length === 0) {
                return <span>{text}</span>;
            }
            
            // Create a regex pattern from all keywords
            const keywordPatterns = Object.keys(keywords).map(k => 
                k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') // Escape regex special chars
            ).join('|');
            
            if (!keywordPatterns) {
                return <span>{text}</span>;
            }
            
            const regex = new RegExp(`(${keywordPatterns})`, 'gi');
            const parts = text.split(regex);
            
            return (
                <React.Fragment>
                    {parts.map((part, i) => {
                        const lowercasePart = part.toLowerCase();
                        const keywordMatch = Object.keys(keywords).find(k => k.toLowerCase() === lowercasePart);
                        
                        if (keywordMatch) {
                            const color = keywords[keywordMatch];
                            return (
                                <span 
                                    key={i} 
                                    className="highlight-keyword" 
                                    style={{ 
                                        textDecoration: 'underline',
                                        textDecorationColor: color,
                                        textDecorationThickness: '2px'
                                    }}>
                                    {part}
                                </span>
                            );
                        }
                        
                        return <span key={i}>{part}</span>;
                    })}
                </React.Fragment>
            );
        };

        // Word-level diff function using jsdiff
        const createWordDiff = (oldText, newText, diffHighlightingEnabled, moveDetectionEnabled, keywords, highlightingEnabled) => {
            const oldLines = oldText.split('\n');
            const newLines = newText.split('\n');
            
            if (!diffHighlightingEnabled && !moveDetectionEnabled) {
                // No highlighting: render plain text rows
                return (
                    <table className="diff-table">
                        <tbody>
                            {Math.max(oldLines.length, newLines.length) > 0 &&
                                [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => (
                                    <tr key={i}>
                                        <td className="line-number">{i+1}</td>
                                        <td>{oldLines[i] || ''}</td>
                                        <td className="line-number">{i+1}</td>
                                        <td>{newLines[i] || ''}</td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                );
            }
            
            // Create a diff for each line pair
            return (
                <table className="diff-table">
                    <tbody>
                        {Math.max(oldLines.length, newLines.length) > 0 && 
                            [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => {
                                const oldLine = oldLines[i] || '';
                                const newLine = newLines[i] || '';

                                // Move detection: highlight lines present elsewhere
                                let oldMovedToLine = -1;
                                const oldMoved = moveDetectionEnabled && 
                                    oldLine.trim() && // Not empty
                                    oldLine !== newLine && // Current position has different content
                                    newLines.some((line, index) => {
                                        if (index !== i && line === oldLine) { // Different position & exact content match
                                            oldMovedToLine = index + 1; // Store the target line number (1-based)
                                            return true;
                                        }
                                        return false;
                                    });
                                
                                let newMovedFromLine = -1;
                                const newMoved = moveDetectionEnabled && 
                                    newLine.trim() && // Not empty
                                    newLine !== oldLine && // Current position has different content
                                    oldLines.some((line, index) => {
                                        if (index !== i && line === newLine) { // Different position & exact content match
                                            newMovedFromLine = index + 1; // Store the source line number (1-based)
                                            return true;
                                        }
                                        return false;
                                    });

                                const oldWordDiff = () => {
                                    if (!oldLine) return null;
                                    if (!diffHighlightingEnabled) return highlightKeywords(oldLine, keywords, highlightingEnabled);
                                    const parts = Diff.diffWordsWithSpace(oldLine, newLine);
                                    return (
                                        <div className="diff-word-line">
                                            {parts.map((part, j) => 
                                                !part.added ? <span key={j} className={part.removed ? 'word-removed' : ''}>{part.value}</span> : null
                                            )}
                                        </div>
                                    );
                                };
                                
                                const newWordDiff = () => {
                                    if (!newLine) return null;
                                    if (!diffHighlightingEnabled) return highlightKeywords(newLine, keywords, highlightingEnabled);
                                    const parts = Diff.diffWordsWithSpace(oldLine, newLine);
                                    return (
                                        <div className="diff-word-line">
                                            {parts.map((part, j) => 
                                                !part.removed ? <span key={j} className={part.added ? 'word-added' : ''}>{part.value}</span> : null
                                            )}
                                        </div>
                                    );
                                };
                                
                                return (
                                    <tr key={i}>
                                        <td className={`line-number ${oldMoved ? 'moved' : ''}`}>
                                            {i+1}
                                            {oldMoved && oldMovedToLine > 0 && <span className="moved-indicator" data-arrow="→">{oldMovedToLine}</span>}
                                        </td>
                                        <td className={oldMoved ? 'moved' : ''}>{oldWordDiff()}</td>
                                        <td className={`line-number ${newMoved ? 'moved' : ''}`}>
                                            {i+1}
                                            {newMoved && newMovedFromLine > 0 && <span className="moved-indicator" data-arrow="←">{newMovedFromLine}</span>}
                                        </td>
                                        <td className={newMoved ? 'moved' : ''}>{newWordDiff()}</td>
                                    </tr>
                                );
                            })
                        }
                    </tbody>
                </table>
            );
        };

        // FileComparison component to show the diff between two files
        const FileComparison = ({ oldContent, newContent, fileInfo, keywords, highlightingEnabled, diffHighlightingEnabled, moveDetectionEnabled, diffMode }) => {
            if (!fileInfo) {
                return (
                    <div className="file-selection-bar">
                        <h2>Welcome to DeltaVision</h2>
                        <p>Compare outputs with powerful diff tools and search capabilities</p>
                        <ul className="welcome-list">
                            <li>Select a file pair from the sidebar to begin</li>
                            <li>Search files and content with the search box</li>
                            <li>Use Move Detection to spot relocated content</li>
                            <li>Switch between Word and Char diff modes</li>
                            <li>Toggle highlights: <strong>Ctrl+H</strong></li>
                            <li>Toggle diffs: <strong>Ctrl+D</strong></li>
                            <li>Toggle diff mode: <strong>Ctrl+M</strong></li>
                            <li>Toggle move detection: <strong>Ctrl+R</strong></li>
                            <li>Toggle sidebar: <strong>Ctrl+E</strong></li>
                            <li>Navigate pairs: <strong>↑</strong> &amp; <strong>↓</strong></li>
                        </ul>
                    </div>
                );
            }

            // Function to find character-level differences within a line
            const enhancedFindDiffInLines = (oldLine, newLine, keywords) => {
                if (oldLine === newLine) {
                    return {
                        oldFormatted: highlightKeywords(oldLine, keywords, highlightingEnabled),
                        newFormatted: highlightKeywords(newLine, keywords, highlightingEnabled)
                    };
                }
                
                // Simple character-level diff implementation
                let i = 0;
                let j = oldLine.length - 1;
                let k = newLine.length - 1;
                
                // Find common prefix
                while (i <= j && i <= k && oldLine.charAt(i) === newLine.charAt(i)) {
                    i++;
                }
                
                // Find common suffix
                while (j >= i && k >= i && oldLine.charAt(j) === newLine.charAt(k)) {
                    j--;
                    k--;
                }
                
                const oldPrefix = oldLine.substring(0, i);
                const oldDiff = oldLine.substring(i, j + 1);
                const oldSuffix = oldLine.substring(j + 1);
                
                const newPrefix = newLine.substring(0, i);
                const newDiff = newLine.substring(i, k + 1);
                const newSuffix = newLine.substring(k + 1);
                
                // Generate formatted output with inline highlighting and keyword highlighting
                const oldFormatted = (
                    <React.Fragment>
                        {highlightKeywords(oldPrefix, keywords, highlightingEnabled)}
                        <span className="diff-char-removed">{highlightKeywords(oldDiff, keywords, highlightingEnabled)}</span>
                        {highlightKeywords(oldSuffix, keywords, highlightingEnabled)}
                    </React.Fragment>
                );
                
                const newFormatted = (
                    <React.Fragment>
                        {highlightKeywords(newPrefix, keywords, highlightingEnabled)}
                        <span className="diff-char-added">{highlightKeywords(newDiff, keywords, highlightingEnabled)}</span>
                        {highlightKeywords(newSuffix, keywords, highlightingEnabled)}
                    </React.Fragment>
                );
                
                return { oldFormatted, newFormatted };
            };

            // Create line-by-line diff
            const createDiff = (oldText, newText, diffHighlightingEnabled, moveDetectionEnabled) => {
                const oldLines = oldText.split('\n');
                const newLines = newText.split('\n');
                
                if (!diffHighlightingEnabled && !moveDetectionEnabled) {
                    // No highlighting: render plain text rows
                    return (
                        <table className="diff-table">
                            <tbody>
                                {Math.max(oldLines.length, newLines.length) > 0 &&
                                    [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => (
                                        <tr key={i}>
                                            <td className="line-number">{i+1}</td>
                                            <td>{oldLines[i] || ''}</td>
                                            <td className="line-number">{i+1}</td>
                                            <td>{newLines[i] || ''}</td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    );
                }
                
                return (
                    <table className="diff-table">
                        <tbody>
                            {Math.max(oldLines.length, newLines.length) > 0 && 
                                [...Array(Math.max(oldLines.length, newLines.length))].map((_, i) => {
                                    const oldLine = oldLines[i] || '';
                                    const newLine = newLines[i] || '';

                                    // Move detection: highlight lines that actually moved positions
                                    let oldMovedToLine = -1;
                                    const oldMoved = moveDetectionEnabled && 
                                        oldLine.trim() && // Not empty
                                        oldLine !== newLine && // Current position has different content
                                        newLines.some((line, index) => {
                                            if (index !== i && line === oldLine) { // Different position & exact content match
                                                oldMovedToLine = index + 1; // Store the target line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });
                                    
                                    let newMovedFromLine = -1;
                                    const newMoved = moveDetectionEnabled && 
                                        newLine.trim() && // Not empty
                                        newLine !== oldLine && // Current position has different content
                                        oldLines.some((line, index) => {
                                            if (index !== i && line === newLine) { // Different position & exact content match
                                                newMovedFromLine = index + 1; // Store the source line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });
                                    
                                    let { oldFormatted, newFormatted } = 
                                        oldLine !== newLine ? enhancedFindDiffInLines(oldLine, newLine, keywords) : 
                                        { 
                                            oldFormatted: highlightKeywords(oldLine, keywords, highlightingEnabled), 
                                            newFormatted: highlightKeywords(newLine, keywords, highlightingEnabled) 
                                        };
                                    
                                    // Choose content based on diffHighlightingEnabled
                                    const oldContent = diffHighlightingEnabled ? oldFormatted : highlightKeywords(oldLine, keywords, highlightingEnabled);
                                    const newContent = diffHighlightingEnabled ? newFormatted : highlightKeywords(newLine, keywords, highlightingEnabled);
                                    
                                    return (
                                        <tr key={i}>
                                            <td className={`line-number ${oldMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {oldMoved && oldMovedToLine > 0 && <span className="moved-indicator" data-arrow="→">{oldMovedToLine}</span>}
                                            </td>
                                            <td className={oldMoved ? 'moved' : ''}>{oldContent}</td>
                                            <td className={`line-number ${newMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {newMoved && newMovedFromLine > 0 && <span className="moved-indicator" data-arrow="←">{newMovedFromLine}</span>}
                                            </td>
                                            <td className={newMoved ? 'moved' : ''}>{newContent}</td>
                                        </tr>
                                    );
                                })
                            }
                        </tbody>
                    </table>
                );
            };

            return (
                <div className="comparison-container">
                    <h3>File Comparison</h3>
                    <div className="filename-display">
                        <div className="row align-items-center mb-3">
                            <div className="col-md-6">
                                <div className="filename-box old-file">
                                    <h5>Old File <span className="file-time">({new Date(fileInfo.oldFile.mtime).toLocaleString()})</span></h5>
                                    <div className="filename">{fileInfo.oldFile.filename}</div>
                                </div>
                            </div>
                            <div className="col-md-6">
                                <div className="filename-box new-file">
                                    <h5>New File <span className="file-time">({new Date(fileInfo.newFile.mtime).toLocaleString()})</span></h5>
                                    <div className="filename">{fileInfo.newFile.filename}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div className="file-details">
                        <div>
                            {fileInfo.commandRan}
                        </div>
                    </div>
                    <div className="diff-container">
                        {diffMode === 'char' ? createDiff(oldContent, newContent, diffHighlightingEnabled, moveDetectionEnabled) : createWordDiff(oldContent, newContent, diffHighlightingEnabled, moveDetectionEnabled, keywords, highlightingEnabled)}
                    </div>
                </div>
            );
        };

        // TimeComparison component to show the diff between newest and older files
        const TimeComparisonView = ({ olderContent, newerContent, fileInfo, keywords, highlightingEnabled, diffHighlightingEnabled, moveDetectionEnabled, diffMode }) => {
            if (!fileInfo) {
                return (
                    <div className="file-selection-bar">
                        <h2>Welcome to DeltaVision</h2>
                        <p>Compare outputs with powerful diff tools and search capabilities</p>
                        <ul className="welcome-list">
                            <li>Select a file pair from the sidebar to begin</li>
                            <li>Search files and content with the search box</li>
                            <li>Use Move Detection to spot relocated content</li>
                            <li>Switch between Word and Char diff modes</li>
                            <li>Toggle highlights: <strong>Ctrl+H</strong></li>
                            <li>Toggle diffs: <strong>Ctrl+D</strong></li>
                            <li>Toggle diff mode: <strong>Ctrl+M</strong></li>
                            <li>Toggle move detection: <strong>Ctrl+R</strong></li>
                            <li>Toggle sidebar: <strong>Ctrl+E</strong></li>
                            <li>Navigate pairs: <strong>↑</strong> &amp; <strong>↓</strong></li>
                        </ul>
                    </div>
                );
            }

            // Function to find character-level differences within a line
            const enhancedFindDiffInLines = (oldLine, newLine, keywords) => {
                if (oldLine === newLine) {
                    return {
                        oldFormatted: highlightKeywords(oldLine, keywords, highlightingEnabled),
                        newFormatted: highlightKeywords(newLine, keywords, highlightingEnabled)
                    };
                }
                
                // Simple character-level diff implementation
                let i = 0;
                let j = oldLine.length - 1;
                let k = newLine.length - 1;
                
                // Find common prefix
                while (i <= j && i <= k && oldLine.charAt(i) === newLine.charAt(i)) {
                    i++;
                }
                
                // Find common suffix
                while (j >= i && k >= i && oldLine.charAt(j) === newLine.charAt(k)) {
                    j--;
                    k--;
                }
                
                const oldPrefix = oldLine.substring(0, i);
                const oldDiff = oldLine.substring(i, j + 1);
                const oldSuffix = oldLine.substring(j + 1);
                
                const newPrefix = newLine.substring(0, i);
                const newDiff = newLine.substring(i, k + 1);
                const newSuffix = newLine.substring(k + 1);
                
                // Generate formatted output with inline highlighting and keyword highlighting
                const oldFormatted = (
                    <React.Fragment>
                        {highlightKeywords(oldPrefix, keywords, highlightingEnabled)}
                        <span className="diff-char-removed">{highlightKeywords(oldDiff, keywords, highlightingEnabled)}</span>
                        {highlightKeywords(oldSuffix, keywords, highlightingEnabled)}
                    </React.Fragment>
                );
                
                const newFormatted = (
                    <React.Fragment>
                        {highlightKeywords(newPrefix, keywords, highlightingEnabled)}
                        <span className="diff-char-added">{highlightKeywords(newDiff, keywords, highlightingEnabled)}</span>
                        {highlightKeywords(newSuffix, keywords, highlightingEnabled)}
                    </React.Fragment>
                );
                
                return { oldFormatted, newFormatted };
            };

            // Create line-by-line diff
            const createDiff = (olderText, newerText, diffHighlightingEnabled, moveDetectionEnabled) => {
                const olderLines = olderText.split('\n');
                const newerLines = newerText.split('\n');
                
                if (!diffHighlightingEnabled && !moveDetectionEnabled) {
                    // No highlighting: render plain text rows
                    return (
                        <table className="diff-table">
                            <tbody>
                                {Math.max(olderLines.length, newerLines.length) > 0 &&
                                    [...Array(Math.max(olderLines.length, newerLines.length))].map((_, i) => (
                                        <tr key={i}>
                                            <td className="line-number">{i+1}</td>
                                            <td>{olderLines[i] || ''}</td>
                                            <td className="line-number">{i+1}</td>
                                            <td>{newerLines[i] || ''}</td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    );
                }
                
                return (
                    <table className="diff-table">
                        <tbody>
                            {Math.max(olderLines.length, newerLines.length) > 0 && 
                                [...Array(Math.max(olderLines.length, newerLines.length))].map((_, i) => {
                                    const olderLine = olderLines[i] || '';
                                    const newerLine = newerLines[i] || '';

                                    // Move detection: highlight lines that actually moved positions
                                    let oldMovedToLine = -1;
                                    const oldMoved = moveDetectionEnabled && 
                                        olderLine.trim() && // Not empty
                                        olderLine !== newerLine && // Current position has different content
                                        newerLines.some((line, index) => {
                                            if (index !== i && line === olderLine) { // Different position & exact content match
                                                oldMovedToLine = index + 1; // Store the target line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });
                                    
                                    let newMovedFromLine = -1;
                                    const newMoved = moveDetectionEnabled && 
                                        newerLine.trim() && // Not empty
                                        newerLine !== olderLine && // Current position has different content
                                        olderLines.some((line, index) => {
                                            if (index !== i && line === newerLine) { // Different position & exact content match
                                                newMovedFromLine = index + 1; // Store the source line number (1-based)
                                                return true;
                                            }
                                            return false;
                                        });
                                    
                                    let { oldFormatted, newFormatted } = 
                                        olderLine !== newerLine ? enhancedFindDiffInLines(olderLine, newerLine, keywords) : 
                                        { 
                                            oldFormatted: highlightKeywords(olderLine, keywords, highlightingEnabled), 
                                            newFormatted: highlightKeywords(newerLine, keywords, highlightingEnabled) 
                                        };
                                    
                                    // Choose content based on diffHighlightingEnabled
                                    const oldContent = diffHighlightingEnabled ? oldFormatted : highlightKeywords(olderLine, keywords, highlightingEnabled);
                                    const newContent = diffHighlightingEnabled ? newFormatted : highlightKeywords(newerLine, keywords, highlightingEnabled);
                                    
                                    return (
                                        <tr key={i}>
                                            <td className={`line-number ${oldMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {oldMoved && oldMovedToLine > 0 && <span className="moved-indicator" data-arrow="→">{oldMovedToLine}</span>}
                                            </td>
                                            <td className={oldMoved ? 'moved' : ''}>{oldContent}</td>
                                            <td className={`line-number ${newMoved ? 'moved' : ''}`}>
                                                {i+1}
                                                {newMoved && newMovedFromLine > 0 && <span className="moved-indicator" data-arrow="←">{newMovedFromLine}</span>}
                                            </td>
                                            <td className={newMoved ? 'moved' : ''}>{newContent}</td>
                                        </tr>
                                    );
                                })
                            }
                        </tbody>
                    </table>
                );
            };

            return (
                <div className="comparison-container">
                    <h3>Time Comparison</h3>
                    <div className="filename-display">
                        <div className="row align-items-center mb-3">
                            <div className="col-md-6">
                                <div className="filename-box old-file">
                                    <h5>Older Run <span className="file-time">({new Date(fileInfo.olderFile.mtime).toLocaleString()})</span> <span className="time-diff">{fileInfo.timeDiff}</span></h5>
                                    <div className="filename">{fileInfo.olderFile.filename}</div>
                                </div>
                            </div>
                            <div className="col-md-6">
                                <div className="filename-box new-file">
                                    <h5>Latest Run <span className="file-time">({new Date(fileInfo.newerFile.mtime).toLocaleString()})</span></h5>
                                    <div className="filename">{fileInfo.newerFile.filename}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div className="file-details">
                        <div>
                            {fileInfo.commandRan}
                        </div>
                    </div>
                    <div className="diff-container">
                        {diffMode === 'char' ? createDiff(olderContent, newerContent, diffHighlightingEnabled, moveDetectionEnabled) : createWordDiff(olderContent, newerContent, diffHighlightingEnabled, moveDetectionEnabled, keywords, highlightingEnabled)}
                    </div>
                </div>
            );
        };

        // Render the App component
        ReactDOM.render(<App />, document.getElementById('app'));

        // Connect the global highlight toggle to the React state
        (() => {
            const globalHighlightToggle = document.getElementById('global-highlight-toggle');
            if (globalHighlightToggle) {
                // Apply the initial state from the global app state
                globalHighlightToggle.checked = window.appState.highlightingEnabled;
                
                // Update the toggle label based on current state
                const updateToggleLabel = () => {
                    const label = document.querySelector('.highlight-toggle-header .toggle-label');
                    if (label) {
                        label.textContent = `Highlights ${globalHighlightToggle.checked ? 'ON' : 'OFF'}`;
                    }
                };
                
                // Initialize state
                updateToggleLabel();
                
                // Add change event listener
                globalHighlightToggle.addEventListener('change', () => {
                    // Update global app state
                    window.appState.highlightingEnabled = globalHighlightToggle.checked;
                    
                    // Update localStorage
                    localStorage.setItem('highlightingEnabled', globalHighlightToggle.checked);
                    
                    // Update the label
                    updateToggleLabel();
                    
                    // Trigger a custom event for the React component to listen to
                    const event = new CustomEvent('highlightToggleChanged', {
                        detail: { enabled: globalHighlightToggle.checked }
                    });
                    document.dispatchEvent(event);
                });
            }
        })();

        // Connect the global diff highlight toggle to the React state
        (() => {
            const globalDiffHighlightToggle = document.getElementById('diff-highlight-toggle');
            if (globalDiffHighlightToggle) {
                // Apply the initial state from the global app state
                globalDiffHighlightToggle.checked = window.appState.diffHighlightingEnabled;
                
                // Update the toggle label based on current state
                const updateToggleLabel = () => {
                    const label = globalDiffHighlightToggle.parentElement.nextElementSibling;
                    if (label) label.textContent = `Diff ${globalDiffHighlightToggle.checked ? 'ON' : 'OFF'}`;
                };
                updateToggleLabel();
                globalDiffHighlightToggle.addEventListener('change', () => {
                    updateToggleLabel();
                    document.dispatchEvent(new CustomEvent('diffHighlightToggleChanged', { detail: { enabled: globalDiffHighlightToggle.checked } }));
                });
            }
        })();

        // Connect the global move detection toggle to the React state
        (() => {
            const globalMoveDetectionToggle = document.getElementById('move-detection-toggle');
            if (globalMoveDetectionToggle) {
                // Apply the initial state from the global app state
                globalMoveDetectionToggle.checked = window.appState.moveDetectionEnabled;
                
                // Update the toggle label based on current state
                const updateToggleLabel = () => {
                    const label = globalMoveDetectionToggle.parentElement.nextElementSibling;
                    if (label) label.textContent = `Detect Moves ${globalMoveDetectionToggle.checked ? 'ON' : 'OFF'}`;
                };
                updateToggleLabel();
                globalMoveDetectionToggle.addEventListener('change', () => {
                    updateToggleLabel();
                    document.dispatchEvent(new CustomEvent('moveDetectionToggleChanged', { detail: { enabled: globalMoveDetectionToggle.checked } }));
                });
            }
        })();

        // Connect the global diff mode toggle to the React state
        (() => {
            const globalDiffModeToggle = document.getElementById('diff-mode-toggle');
            if (globalDiffModeToggle) {
                const updateLabel = () => {
                    const label = globalDiffModeToggle.parentElement.nextElementSibling;
                    if (label) label.textContent = `Diff ${globalDiffModeToggle.checked ? 'Word' : 'Char'}`;
                };
                updateLabel();
                globalDiffModeToggle.addEventListener('change', () => {
                    updateLabel();
                    document.dispatchEvent(new CustomEvent('diffModeToggle', { detail: { mode: globalDiffModeToggle.checked ? 'word' : 'char' } }));
                });
            }
        })();

        // Theme switching is now handled by theme-manager.js
        // No need for manual event listeners here
        
        // Settings modal functionality
        const settingsButton = document.getElementById('settings-button');
        const settingsModal = document.getElementById('settings-modal');
        const closeModalButton = document.getElementById('close-modal');
        const cancelSettingsButton = document.getElementById('cancel-settings');
        const saveSettingsButton = document.getElementById('save-settings');
        const oldFolderInput = document.getElementById('old-folder-path');
        const newFolderInput = document.getElementById('new-folder-path');
        const keywordFileInput = document.getElementById('keyword-file-path');
        
        // Show settings modal
        settingsButton.addEventListener('click', () => {
            settingsModal.classList.add('active');
        });
        
        // Hide settings modal
        function hideModal() {
            settingsModal.classList.remove('active');
        }
        
        closeModalButton.addEventListener('click', hideModal);
        cancelSettingsButton.addEventListener('click', hideModal);
        
        // Save settings
        saveSettingsButton.addEventListener('click', async () => {
            const oldFolderPath = oldFolderInput.value.trim();
            const newFolderPath = newFolderInput.value.trim();
            const keywordFilePath = keywordFileInput.value.trim();
            
            // Validate paths
            let isValid = true;
            
            if (!oldFolderPath) {
                document.getElementById('old-folder-error').textContent = 'Old folder path is required';
                isValid = false;
            } else {
                document.getElementById('old-folder-error').textContent = '';
            }
            
            if (!newFolderPath) {
                document.getElementById('new-folder-error').textContent = 'New folder path is required';
                isValid = false;
            } else {
                document.getElementById('new-folder-error').textContent = '';
            }
            
            // Keyword file path is optional, no validation needed
            document.getElementById('keyword-file-error').textContent = '';
            
            if (isValid) {
                try {
                    const response = await fetch('/api/folders', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            oldFolder: oldFolderPath,
                            newFolder: newFolderPath,
                            keywordFile: keywordFilePath
                        })
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        // Show success message
                        const statusEl = document.getElementById('settings-status');
                        statusEl.textContent = `Settings saved successfully${data.keywordCount > 0 ? `. Loaded ${data.keywordCount} keywords` : ''}`;
                        statusEl.classList.add('success');
                        statusEl.classList.remove('error');
                        statusEl.style.display = 'block';
                        
                        // Hide message after 3 seconds
                        setTimeout(() => {
                            statusEl.style.display = 'none';
                        }, 3000);
                        
                        // Hide modal
                        hideModal();
                        
                        // Reload page to refresh data
                        setTimeout(() => {
                            window.location.reload();
                        }, 500);
                    } else {
                        // Show error message
                        if (data.error && data.error.includes('Old folder')) {
                            document.getElementById('old-folder-error').textContent = data.error;
                        } else if (data.error && data.error.includes('New folder')) {
                            document.getElementById('new-folder-error').textContent = data.error;
                        } else if (data.error && data.error.includes('Keyword file')) {
                            document.getElementById('keyword-file-error').textContent = data.error;
                        } else {
                            const statusEl = document.getElementById('settings-status');
                            statusEl.textContent = data.error || 'Failed to save settings';
                            statusEl.classList.add('error');
                            statusEl.classList.remove('success');
                            statusEl.style.display = 'block';
                        }
                    }
                } catch (error) {
                    console.error('Error saving settings:', error);
                }
            }
        });

        // Close modal when clicking outside
        settingsModal.addEventListener('click', (e) => {
            if (e.target === settingsModal) {
                hideModal();
            }
        });

        // Load saved folder paths on page load
        document.addEventListener('DOMContentLoaded', () => {
            loadFolderPaths();
            
            // Set up settings modal
            const settingsButton = document.getElementById('settings-button');
            const settingsModal = document.getElementById('settings-modal');
            const closeModal = document.getElementById('close-modal');
            const cancelSettings = document.getElementById('cancel-settings');
            const saveSettings = document.getElementById('save-settings');
            const oldFolderInput = document.getElementById('old-folder-path');
            const newFolderInput = document.getElementById('new-folder-path');
            const keywordFileInput = document.getElementById('keyword-file-path');
            
            // Show settings modal
            settingsButton.addEventListener('click', () => {
                settingsModal.classList.add('active');
            });
            
            // Hide settings modal
            function hideModal() {
                settingsModal.classList.remove('active');
            }
            
            closeModal.addEventListener('click', hideModal);
            cancelSettings.addEventListener('click', hideModal);
            
            // Save settings
            saveSettings.addEventListener('click', async () => {
                const oldFolderPath = oldFolderInput.value.trim();
                const newFolderPath = newFolderInput.value.trim();
                const keywordFilePath = keywordFileInput.value.trim();
                
                // Validate paths
                let isValid = true;
                
                if (!oldFolderPath) {
                    document.getElementById('old-folder-error').textContent = 'Old folder path is required';
                    isValid = false;
                } else {
                    document.getElementById('old-folder-error').textContent = '';
                }
                
                if (!newFolderPath) {
                    document.getElementById('new-folder-error').textContent = 'New folder path is required';
                    isValid = false;
                } else {
                    document.getElementById('new-folder-error').textContent = '';
                }
                
                // Keyword file path is optional, no validation needed
                document.getElementById('keyword-file-error').textContent = '';
                
                if (isValid) {
                    try {
                        const response = await fetch('/api/folders', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                oldFolder: oldFolderPath,
                                newFolder: newFolderPath,
                                keywordFile: keywordFilePath
                            })
                        });
                        
                        const data = await response.json();
                        
                        if (response.ok) {
                            // Show success message
                            const statusEl = document.getElementById('settings-status');
                            statusEl.textContent = `Settings saved successfully${data.keywordCount > 0 ? `. Loaded ${data.keywordCount} keywords` : ''}`;
                            statusEl.classList.add('success');
                            statusEl.classList.remove('error');
                            statusEl.style.display = 'block';
                            
                            // Hide message after 3 seconds
                            setTimeout(() => {
                                statusEl.style.display = 'none';
                            }, 3000);
                            
                            // Hide modal
                            hideModal();
                            
                            // Reload page to refresh data
                            setTimeout(() => {
                                window.location.reload();
                            }, 500);
                        } else {
                            // Show error message
                            if (data.error && data.error.includes('Old folder')) {
                                document.getElementById('old-folder-error').textContent = data.error;
                            } else if (data.error && data.error.includes('New folder')) {
                                document.getElementById('new-folder-error').textContent = data.error;
                            } else if (data.error && data.error.includes('Keyword file')) {
                                document.getElementById('keyword-file-error').textContent = data.error;
                            } else {
                                const statusEl = document.getElementById('settings-status');
                                statusEl.textContent = data.error || 'Failed to save settings';
                                statusEl.classList.add('error');
                                statusEl.classList.remove('success');
                                statusEl.style.display = 'block';
                            }
                        }
                    } catch (error) {
                        console.error('Error saving settings:', error);
                    }
                }
            });

            // Close modal when clicking outside the content
            settingsModal.addEventListener('click', (e) => {
                if (e.target === settingsModal) {
                    hideModal();
                }
            });
        });
        
        // Load folder paths from server
        async function loadFolderPaths() {
            try {
                const response = await fetch('/api/folders');
                const data = await response.json();
                
                if (data.oldFolderPath && data.newFolderPath) {
                    document.getElementById('old-folder-path').value = data.oldFolderPath;
                    document.getElementById('new-folder-path').value = data.newFolderPath;
                }
                
                if (data.keywordFilePath) {
                    document.getElementById('keyword-file-path').value = data.keywordFilePath;
                }
            } catch (error) {
                console.error('Error loading folder paths:', error);
            }
        }
    </script>
    <script>
        // Consolidated keyboard shortcuts handler for all application functions
        document.addEventListener('DOMContentLoaded', function() {
            document.addEventListener('keydown', function(e) {
                // Skip if we're in an input or textarea
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
                    return;
                }
                
                // Sidebar toggle: Ctrl+E
                if (e.ctrlKey && e.key.toLowerCase() === 'e') {
                    e.preventDefault();
                    const sidebarToggle = document.querySelector('.toggle-sidebar');
                    if (sidebarToggle) sidebarToggle.click();
                }
                
                // Highlight toggle: Ctrl+H
                if (e.ctrlKey && e.key.toLowerCase() === 'h') {
                    e.preventDefault();
                    const hlToggle = document.getElementById('global-highlight-toggle');
                    if (hlToggle) {
                        hlToggle.checked = !hlToggle.checked;
                        hlToggle.dispatchEvent(new Event('change'));
                    }
                }
                
                // Diff toggle: Ctrl+D
                if (e.ctrlKey && e.key.toLowerCase() === 'd') {
                    e.preventDefault();
                    const diffToggle = document.getElementById('diff-highlight-toggle');
                    if (diffToggle) {
                        diffToggle.checked = !diffToggle.checked;
                        diffToggle.dispatchEvent(new Event('change'));
                    }
                }
                
                // Char diff toggle: Ctrl+M
                if (e.ctrlKey && e.key.toLowerCase() === 'm') {
                    e.preventDefault();
                    const modeToggle = document.getElementById('diff-mode-toggle');
                    if (modeToggle) {
                        modeToggle.checked = !modeToggle.checked;
                        modeToggle.dispatchEvent(new Event('change'));
                    }
                }
                
                // Move detection toggle: Ctrl+R
                if (e.ctrlKey && e.key.toLowerCase() === 'r') {
                    e.preventDefault();
                    const moveDetectionToggle = document.getElementById('move-detection-toggle');
                    if (moveDetectionToggle) {
                        moveDetectionToggle.checked = !moveDetectionToggle.checked;
                        moveDetectionToggle.dispatchEvent(new Event('change'));
                    }
                }
                
                // Mode toggles: Ctrl+1 and Ctrl+2 for different view modes
                if (e.ctrlKey && e.key === '1') {
                    e.preventDefault();
                    const inlineButton = document.querySelector('.mode-toggle button:first-child');
                    if (inlineButton) inlineButton.click();
                }
                
                if (e.ctrlKey && e.key === '2') {
                    e.preventDefault();
                    const sideBySideButton = document.querySelector('.mode-toggle button:last-child');
                    if (sideBySideButton) sideBySideButton.click();
                }

                // Navigation with arrow keys
                if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    const app = document.getElementById('app');
                    if (app) {
                        const fileEntries = app.querySelectorAll('.file-entry');
                        if (fileEntries.length > 0) {
                            const currentIndex = Array.prototype.indexOf.call(fileEntries, document.querySelector('.file-entry.selected'));
                            const newIndex = currentIndex <= 0 ? 0 : currentIndex - 1;
                            fileEntries[newIndex].click();
                        }
                    }
                }
                
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    const app = document.getElementById('app');
                    if (app) {
                        const fileEntries = app.querySelectorAll('.file-entry');
                        if (fileEntries.length > 0) {
                            const currentIndex = Array.prototype.indexOf.call(fileEntries, document.querySelector('.file-entry.selected'));
                            const newIndex = currentIndex === -1 ? 0 : Math.min(fileEntries.length - 1, currentIndex + 1);
                            fileEntries[newIndex].click();
                        }
                    }
                }
            });
            
            // Add the has-hotkey class to elements with tooltips to make them visible on hover
            document.querySelectorAll('.hotkey-tooltip').forEach(tooltip => {
                tooltip.parentElement.classList.add('has-hotkey');
            });
