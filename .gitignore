# Dependencies
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.npm/

# Keep npm-packages directory structure but ignore contents
npm-packages/*
# But include .gitkeep to preserve directory structure
!npm-packages/.gitkeep

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build artifacts
/build
/dist

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Folder configurations and data
sample-data/

# Logs
logs/*
!logs/.gitkeep
*.log

# Docker/Podman
*.tar
container-engine.txt
compose-available.txt
compose-cmd.txt

# Package files - exclude from repo, but keep local builds
deltavision-*.zip
scripts/deltavision-*.zip

# Temporary files
.tmp/
temp/

# Exception: Include precompiled binaries
!precompiled/node/
!precompiled/node/**/*

# Default folder-config.json should be included 
!folder-config.json
