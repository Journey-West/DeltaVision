{
  "name": "deltavision",
  "version": "1.0.0",
  "description": "DeltaVision - A tool to visualize differences between files in Old and New folders",
  "main": "src/server/index.js",
  "bin": {
    "deltavision": "bin/deltavision.js"
  },
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "nodemon src/server/index.js",
    "docker:build": "docker build -t deltavision .",
    "docker:run": "docker run -p 3000:3000 -v /path/to/your/old/folder:/app/data/old -v /path/to/your/new/folder:/app/data/new -v $(pwd)/folder-config.json:/app/folder-config.json -v $(pwd)/keywords.txt:/app/keywords.txt deltavision",
    "docker:compose": "docker-compose up -d"
  },
  "dependencies": {
    "express": "^4.18.2",
    "diff": "^5.1.0",
    "chokidar": "^3.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-diff-viewer-continued": "^3.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}